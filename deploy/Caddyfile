# Caddy リバースプロキシ設定（自動 HTTPS）
#
# mypokeca.com の A レコードがこのサーバーの固定IPを指していれば、
# Caddy が Let's Encrypt から証明書を自動取得・更新する。
# 証明書取得には 80/443 が公開されている必要がある。

mypokeca.com {
	# Basic 認証（ユーザー名/bcryptハッシュは環境変数で注入）。
	# 値は VPS 上の .env.caddy で与える（git 管理外）。
	basic_auth {
		{$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
	}

	reverse_proxy webapp:5000

	# 簡易アクセスログ（必要なら）
	log {
		output stdout
		format console
	}
}

# www からのアクセスを裸ドメインへリダイレクト（任意。
# www.mypokeca.com の A/CNAME を設定した場合に有効）
www.mypokeca.com {
	redir https://mypokeca.com{uri} permanent
}
